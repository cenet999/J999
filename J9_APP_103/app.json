{
  "expo": {
    "name": "久游俱乐部",
    "slug": "j9-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "j9-club",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.j9club.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "九游俱乐部需要访问您的相册以选择图片。我们仅会在您主动选择图片时访问相册，不会在后台访问或读取其他照片。",
        "NSPhotoLibraryAddUsageDescription": "九游俱乐部需要保存图片到您的相册。",
        "NSCameraUsageDescription": "九游俱乐部需要访问您的相机以拍摄照片。我们仅在您主动使用拍照功能时访问相机，不会在后台使用相机。",
        "NSUserNotificationsUsageDescription": "应用需要发送推送通知以提醒您重要信息"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.j9club.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.NOTIFICATIONS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "九游俱乐部需要访问您的相册以选择头像图片。我们仅会在您主动更换头像时访问相册，不会在后台访问或读取其他照片。",
          "cameraPermission": "九游俱乐部需要访问您的相机以拍摄头像图片。我们仅在您主动拍照更换头像时访问相机，不会在后台使用相机。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/splash.png",
          "resizeMode": "contain",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "enabled": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "80f9bce0-9f40-40a6-8fd2-1aea72292e7c"
      }
    }
  }
}
