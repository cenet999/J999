# ============================================
# Stage 1: Build Expo web static files
# ============================================
FROM node:20-alpine AS builder

WORKDIR /app

# 与本地开发一致使用 pnpm；仅用 npm ci 会因 package-lock 与 package.json 不同步而失败
RUN corepack enable

# 可选：国内镜像加速（部署到海外可删掉）
# RUN pnpm config set registry https://registry.npmmirror.com

# 须含 .npmrc（如 node-linker=hoisted），否则与本地 Metro/解析行为不一致
COPY package.json pnpm-lock.yaml .npmrc ./
RUN pnpm install --frozen-lockfile

COPY . .
# 强制生产模式，确保 __DEV__=false（登录页不预填、API 走生产地址）
ENV NODE_ENV=production
RUN pnpm run build:web

# ============================================
# Stage 2: Serve with nginx
# ============================================
FROM nginx:alpine

# 复制构建产物（Expo 导出到 dist）
COPY --from=builder /app/dist /usr/share/nginx/html

# gzip + 静态资源缓存（见 nginx/default.conf）
COPY nginx/default.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
