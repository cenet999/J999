@page "/Ddd/DTask"
@using J9_Admin.Entities

<AdminTable2 TItem="DTask" Context="item" PageSize="50" Title="每日任务管理" DialogClassName="modal-lg"
    OnQuery="OnQuery" InitQuery="InitQuery" OnEdit="OnEdit">

    <TableHeader>
        <th>任务类型</th>
        <th>任务名称</th>
        <th>目标值</th>
        <th>奖励金额</th>
        <th>活跃度</th>
        <th>状态</th>
        <th>排序</th>
        <th>创建时间</th>
    </TableHeader>
    <TableRow>
        <td>@item.TaskType</td>
        <td>@item.Title</td>
        <td>@item.TargetValue</td>
        <td>@item.RewardAmount</td>
        <td>@item.ActivityPoint</td>
        <td>
            <Switch Value="item.IsEnabled" IsDisabled="true" OnColor="Color.Success" />
        </td>
        <td>@item.Sort</td>
        <td>@item.CreatedTime?.ToString("yyyy-MM-dd HH:mm:ss")</td>
    </TableRow>
    <EditTemplate>
        <div class="row">
            <div class="form-group col-6">
                <label class="form-label">任务名称</label>
                <input @bind="item.Title" type="text" class="form-control" maxlength="255">
            </div>
            <div class="form-group col-6">
                <label class="form-label">任务类型</label>
                <input @bind="item.TaskType" type="text" class="form-control" placeholder="如 Login, Bet, Recharge" maxlength="255">
            </div>
            <div class="form-group col-12">
                <label class="form-label">任务描述</label>
                <textarea @bind="item.Description" class="form-control" maxlength="65535"></textarea>
            </div>
            <div class="form-group col-4">
                <label class="form-label">目标值</label>
                <input @bind="item.TargetValue" type="number" class="form-control">
            </div>
            <div class="form-group col-4">
                <label class="form-label">奖励金额</label>
                <input @bind="item.RewardAmount" type="number" step="0.01" class="form-control">
            </div>
            <div class="form-group col-4">
                <label class="form-label">活跃度</label>
                <input @bind="item.ActivityPoint" type="number" class="form-control">
            </div>
            <div class="form-group col-6">
                <label class="form-label">任务状态</label>
                <Switch @bind-Value="item.IsEnabled" OnColor="Color.Success" />
            </div>
            <div class="form-group col-6">
                <label class="form-label">排序</label>
                <input @bind="item.Sort" type="number" class="form-control">
            </div>
            <div class="form-group col-6">
                <label class="form-label">图标</label>
                <input @bind="item.Icon" type="text" class="form-control">
            </div>
            <div class="form-group col-6">
                <label class="form-label">跳转路径</label>
                <input @bind="item.JumpPath" type="text" class="form-control">
            </div>
        </div>
    </EditTemplate> 
</AdminTable2>

@code {
    [Inject] IAggregateRootRepository<DTask> repo { get; set; }

    async Task InitQuery(AdminQueryInfo e)
    {
        e.Filters = new AdminFilterInfo[]
        {
            
        };
        await Task.Yield();
    }
    void OnQuery(AdminQueryEventArgs<DTask> e)
    {
        e.Select
            .WhereIf(!e.SearchText.IsNull(), a => a.Title.Contains(e.SearchText) || 
                a.Description.Contains(e.SearchText) || 
                a.TaskType.Contains(e.SearchText))
            .OrderByDescending(a => a.Id);
    }

    async Task OnEdit(DTask item)
    {
        await Task.Yield();
    }
}
