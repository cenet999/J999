        TransactionType.Bet => "投注",
        TransactionType.Withdraw => "提现",
        TransactionType.Recharge => "充值",
        TransactionType.Refund => "退款",
        TransactionType.Commission => "返佣",
        TransactionType.Activity => "活动",
        TransactionType.Other => "其他",
        TransactionType.AgentTransferIn => "代理上分",
        TransactionType.AgentTransferOut => "代理下分",
        TransactionType.Rebate => "反水",
        TransactionType.AgentRecharge => "代理充值",
        TransactionType.Login => "登录",
