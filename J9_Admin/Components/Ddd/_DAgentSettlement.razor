@page "/Ddd/DAgentSettlement"
@using System.Globalization
@using J9_Admin.Utils

<PageTitle>代理结算</PageTitle>

<div class="p-3">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="mb-1">代理结算</h5>
                    <div class="text-muted small">按月汇总会员流水与充值。应付金额仅含二级 + 三级对应部分，且须线上至少存在二级代理；若仅有单一一级代理则应付为 0。分成规则：无二级、三级时份额并入一级；仅有二级时三级份额按一级、二级比例（与 0.002:0.003 同比）分给链上前两级；有一二三级则按 0.002 / 0.003 / 0.005 分配给链末端三级。</div>
                </div>
            </div>

            <div class="row g-2 align-items-end mb-3">
                <div class="col-2">
                    <label class="form-label">月份</label>
                    <select class="form-select form-control-sm" value="@queryMonth" @onchange="OnQueryMonthChanged">
                        @foreach (var m in monthOptions)
                        {
                            <option value="@m">@m</option>
                        }
                    </select>
                </div>
                <div class="col-1">
                    <label class="form-label">关键词</label>
                    <input @bind="keyword" type="text" class="form-control" placeholder="可搜代理名 / 会员名" maxlength="50">
                </div>
                <div class="col-1">
                    <button type="button" class="btn btn-primary" @onclick="LoadRowsAsync" disabled="@loading">查询</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetFilters" disabled="@loading">重置</button>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">流水总计</div>
                        <div class="fs-5 fw-bold">@totalTurnover.ToString("0.##")</div>
                    </div>
                </div>
                <div class="col-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">充值总计</div>
                        <div class="fs-5 fw-bold">@totalRecharge.ToString("0.##")</div>
                    </div>
                </div>
                <div class="col-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">应付总计</div>
                        <div class="fs-5 fw-bold text-danger">@totalPayable.ToString("0.##")</div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(loadError))
            {
                <div class="alert alert-warning">@loadError</div>
            }

            @if (loading)
            {
                <div class="text-muted">数据加载中...</div>
            }
            else if (rows.Count == 0)
            {
                <div class="alert alert-light border">暂无结算数据</div>
            }
            else
            {
                <div class="mb-4">
                    <div class="fw-semibold mb-2 border-start border-success border-3 ps-2">当前代理获利（按代理汇总）</div>
                    @if (spendSummaryCurrent.Count == 0)
                    {
                        <div class="text-muted small">暂无</div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var c in spendSummaryCurrent)
                            {
                                <div class="col-2">
                                    <div class="card h-100 border-success shadow-sm">
                                        <div class="card-body p-3">
                                            <div class="small text-muted text-truncate" title="@c.Name">@c.Name</div>
                                            <div class="fs-6 fw-bold text-success">@c.Amount.ToString("0.##")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="small text-muted mt-2">小计：<span class="fw-semibold text-success">@spendSummaryCurrent.Sum(x => x.Amount).ToString("0.##")</span></div>
                    }
                </div>

                <div class="mb-4">
                    <div class="fw-semibold mb-2 border-start border-info border-3 ps-2">下级代理支出（按代理汇总）</div>
                    @if (spendSummaryChild.Count == 0)
                    {
                        <div class="text-muted small">暂无</div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var c in spendSummaryChild)
                            {
                                <div class="col-2">
                                    <div class="card h-100 border-info shadow-sm">
                                        <div class="card-body p-3">
                                            <div class="small text-muted text-truncate" title="@c.Name">@c.Name</div>
                                            <div class="fs-6 fw-bold text-info">@c.Amount.ToString("0.##")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="small text-muted mt-2">小计：<span class="fw-semibold text-info">@spendSummaryChild.Sum(x => x.Amount).ToString("0.##")</span></div>
                    }
                </div>

                <div class="mb-4">
                    <div class="fw-semibold mb-2 border-start border-warning border-3 ps-2">二级代理支出（子子代理，按代理汇总）</div>
                    @if (spendSummaryGrandChild.Count == 0)
                    {
                        <div class="text-muted small">暂无</div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var c in spendSummaryGrandChild)
                            {
                                <div class="col-2">
                                    <div class="card h-100 border-warning shadow-sm">
                                        <div class="card-body p-3">
                                            <div class="small text-muted text-truncate" title="@c.Name">@c.Name</div>
                                            <div class="fs-6 fw-bold text-warning">@c.Amount.ToString("0.##")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="small text-muted mt-2">小计：<span class="fw-semibold text-warning">@spendSummaryGrandChild.Sum(x => x.Amount).ToString("0.##")</span></div>
                    }
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>月份</th>
                                <th>当前代理</th>
                                <th>下级代理</th>
                                <th>二级代理</th>
                                <th>当前代理获利</th>
                                <th>下级获利</th>
                                <th>二级获利</th>
                                <th>会员名</th>
                                <th>流水统计</th>
                                <th>充值统计</th>
                                <th>比例</th>
                                <th>应付金额</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in rows)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.MonthText</td>
                                    <td>@item.CurrentAgentName</td>
                                    <td>@item.ChildAgentName</td>
                                    <td>@item.GrandChildAgentName</td>
                                    <td><span class="badge bg-success">@item.CurrentAgentProfit.ToString("0.##")</span></td>
                                    <td>@item.ChildAgentProfit.ToString("0.##")</td>
                                    <td>@item.GrandChildAgentProfit.ToString("0.##")</td>
                                    <td>@item.MemberName</td>
                                    <td>@item.TurnoverAmount.ToString("0.##")</td>
                                    <td>@item.RechargeAmount.ToString("0.##")</td>
                                    <td>@item.RateText</td>
                                    <td class="text-danger fw-bold">@item.PayableAmount.ToString("0.##")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {

    // 一级 / 二级 / 三级 在一条线上对会员流水的抽成比例。
    // 仅一级：三者并入一级。仅有二级：三级份额按一级、二级比例（Tier1:Tier2）分摊给链上两级。有一二三：末端三级按 Tier1/Tier2/Tier3 分配。
    const decimal Tier1RebateRate = 0.002m;
    const decimal Tier2RebateRate = 0.003m;
    const decimal Tier3RebateRate = 0.005m;
    // 三档合计；仅链上一名代理时全额归该代理。
    const decimal TotalCombinedTierRate = Tier1RebateRate + Tier2RebateRate + Tier3RebateRate;

    [Inject] IAggregateRootRepository<DTransAction> repo { get; set; }
    [Inject] J9_Admin.Utils.SessionAgent sessionAgent { get; set; }
    [Inject] AdminContext AdminContext { get; set; }

    List<AgentSettlementRow> rows = [];
    List<SpendCardItem> spendSummaryCurrent = [];
    List<SpendCardItem> spendSummaryChild = [];
    List<SpendCardItem> spendSummaryGrandChild = [];
    bool loading;
    string loadError = "";
    string queryMonth = DateTime.Now.ToString("yyyy-MM");
    string keyword = "";
    readonly List<string> monthOptions = BuildMonthOptions();
    decimal totalTurnover;
    decimal totalRecharge;
    decimal totalPayable;

    static List<string> BuildMonthOptions()
    {
        var list = new List<string>();
        var cur = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        for (var i = 0; i < 6; i++)
            list.Add(cur.AddMonths(-i).ToString("yyyy-MM"));
        return list;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRowsAsync();
    }

    async Task OnQueryMonthChanged(ChangeEventArgs e)
    {
        var v = e.Value?.ToString();
        if (!string.IsNullOrEmpty(v))
            queryMonth = v;
        await LoadRowsAsync();
    }

    async Task LoadRowsAsync()
    {
        loading = true;
        loadError = "";
        rows = [];
        spendSummaryCurrent = [];
        spendSummaryChild = [];
        spendSummaryGrandChild = [];
        totalTurnover = 0;
        totalRecharge = 0;
        totalPayable = 0;

        try
        {
            if (!TryParseMonth(queryMonth, out var monthStart, out var nextMonth))
            {
                loadError = "月份格式不对，请按 2026-04 这种格式填写。";
                return;
            }

            var monthStartUnix = TimeHelper.LocalToUnix(monthStart);
            var nextMonthUnix = TimeHelper.LocalToUnix(nextMonth);


            var agents = await repo.Orm.Select<DAgent>().ToListAsync();
            var agentMap = agents.ToDictionary(a => a.Id);

            var visibleAgentIds = VisibleAgentIdsHelper.Build(
                agents,
                string.Equals(AdminContext.User?.Username, "admin", StringComparison.OrdinalIgnoreCase),
                sessionAgent.GetAgentId());
            if (visibleAgentIds.Count == 0)
            {
                loadError = "当前账号没有可查看的代理数据。";
                return;
            }

            var visibleAgentIdList = visibleAgentIds.ToList();
            var members = await repo.Orm.Select<DMember>()
                .Where(m => visibleAgentIdList.Contains(m.DAgentId))
                .Where(m => !m.IsSystem)
                .ToListAsync();

            // 这里只取结算页当前真正关心的两类数据：投注和充值，而且只看成功单。
            var trans = await repo.Orm.Select<DTransAction>()
                .Include(t => t.DMember)
                .Where(t => visibleAgentIdList.Contains(t.DAgentId))
                .Where(t => t.Status == TransactionStatus.Success)
                .Where(t => t.TransactionTime >= monthStartUnix && t.TransactionTime < nextMonthUnix)
                .Where(t => t.TransactionType == TransactionType.Bet || t.TransactionType == TransactionType.Recharge)
                .ToListAsync();

            var settlementRows = trans
                .GroupBy(t =>
                {
                    var wall = TimeHelper.UnixToLocal(t.TransactionTime);
                    return new
                    {
                        Month = new DateTime(wall.Year, wall.Month, 1),
                        t.DAgentId,
                        t.DMemberId
                    };
                })
                .Select(g => BuildSettlementRow(g.ToList(), agentMap))
                .Where(r => r != null)
                .Cast<AgentSettlementRow>()
                .ToList();

            var memberIdsWithRows = settlementRows
                .Where(r => r.MemberId > 0)
                .Select(r => r.MemberId)
                .ToHashSet();

            var emptyMemberRows = members
                .Where(m => agentMap.ContainsKey(m.DAgentId) && !memberIdsWithRows.Contains(m.Id))
                .Select(m => BuildEmptyMemberRow(m, agentMap, monthStart));

            // 如果某个代理下面一个会员都没有，也补一条 0 数据，保证代理也能看到。
            var agentIdsWithMembers = members.Select(m => m.DAgentId).ToHashSet();
            var agentIdsWithRows = settlementRows.Select(r => r.AgentId).ToHashSet();
            var emptyAgentRows = visibleAgentIdList
                .Where(agentId => agentMap.ContainsKey(agentId))
                .Where(agentId => !agentIdsWithMembers.Contains(agentId) && !agentIdsWithRows.Contains(agentId))
                .Select(agentId => BuildEmptyAgentRow(agentMap[agentId], agentMap, monthStart));

            settlementRows = settlementRows
                .Concat(emptyMemberRows)
                .Concat(emptyAgentRows)
                .OrderByDescending(r => r.Month)
                .ThenBy(r => r.CurrentAgentName)
                .ThenBy(r => r.ChildAgentName)
                .ThenBy(r => r.GrandChildAgentName)
                .ThenBy(r => r.MemberName)
                .ToList();

            if (!string.IsNullOrWhiteSpace(keyword))
            {
                var text = keyword.Trim();
                settlementRows = settlementRows.Where(r =>
                    r.CurrentAgentName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                    r.ChildAgentName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                    r.GrandChildAgentName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                    r.MemberName.Contains(text, StringComparison.OrdinalIgnoreCase)).ToList();
            }

            for (var i = 0; i < settlementRows.Count; i++)
                settlementRows[i].Id = i + 1;

            rows = settlementRows;

            totalTurnover = rows.Sum(r => r.TurnoverAmount);
            totalRecharge = rows.Sum(r => r.RechargeAmount);
            totalPayable = rows.Sum(r => r.PayableAmount);
            RebuildSpendCardSummaries();
        }
        catch (Exception ex)
        {
            loadError = $"加载失败：{ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    void ResetFilters()
    {
        queryMonth = DateTime.Now.ToString("yyyy-MM");
        keyword = "";
        _ = LoadRowsAsync();
    }

    void RebuildSpendCardSummaries()
    {
        static bool Named(string? s) =>
            !string.IsNullOrWhiteSpace(s) && s != "-";

        spendSummaryCurrent = rows
            .Where(r => Named(r.CurrentAgentName))
            .GroupBy(r => r.CurrentAgentName)
            .Select(g => new SpendCardItem { Name = g.Key, Amount = g.Sum(x => x.CurrentAgentProfit) })
            .OrderByDescending(x => x.Amount)
            .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        spendSummaryChild = rows
            .Where(r => Named(r.ChildAgentName))
            .GroupBy(r => r.ChildAgentName)
            .Select(g => new SpendCardItem { Name = g.Key, Amount = g.Sum(x => x.ChildAgentProfit) })
            .OrderByDescending(x => x.Amount)
            .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        spendSummaryGrandChild = rows
            .Where(r => Named(r.GrandChildAgentName))
            .GroupBy(r => r.GrandChildAgentName)
            .Select(g => new SpendCardItem { Name = g.Key, Amount = g.Sum(x => x.GrandChildAgentProfit) })
            .OrderByDescending(x => x.Amount)
            .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    AgentSettlementRow? BuildSettlementRow(List<DTransAction> groupRows, Dictionary<long, DAgent> agentMap)
    {
        var first = groupRows.FirstOrDefault();
        if (first == null || !agentMap.TryGetValue(first.DAgentId, out var agent))
            return null;

        var display = GetAgentDisplayInfo(agent, agentMap);
        var chain = BuildChainRootToAgent(agent, agentMap);

        var turnoverAmount = groupRows
            .Where(t => t.TransactionType == TransactionType.Bet)
            .Sum(t => t.BetAmount);

        var rechargeAmount = groupRows
            .Where(t => t.TransactionType == TransactionType.Recharge)
            .Sum(t => t.ActualAmount);

        var shares = ComputeAgentCommissionShares(chain, turnoverAmount);

        decimal SlotProfit(DAgent? a) =>
            a == null ? 0 : shares.GetValueOrDefault(a.Id);

        // 应付金额：仅二级+三级；线上无二级、三级代理（链上仅一级）时为 0
        var payableRate = Tier2RebateRate + Tier3RebateRate;
        var payableAmount = 0m;
        if (chain.Count >= 2 && turnoverAmount > 0)
            payableAmount = RoundMoney(turnoverAmount * payableRate);

        decimal ratioCol = payableRate;
        var rateText = FormatPayableRateText();
        if (chain.Count < 2 && turnoverAmount > 0)
        {
            ratioCol = 0;
            rateText = "—（无二级、三级代理）";
        }

        var firstWall = TimeHelper.UnixToLocal(first.TransactionTime);
        return new AgentSettlementRow
        {
            AgentId = agent.Id,
            MemberId = first.DMemberId,
            Month = new DateTime(firstWall.Year, firstWall.Month, 1),
            MonthText = firstWall.ToString("yyyy-MM"),
            CurrentAgentName = display.CurrentAgentName,
            ChildAgentName = display.ChildAgentName,
            GrandChildAgentName = display.GrandChildAgentName,
            MemberName = first.DMember?.Username ?? $"会员ID:{first.DMemberId}",
            TurnoverAmount = turnoverAmount,
            RechargeAmount = rechargeAmount,
            Ratio = ratioCol,
            RateText = rateText,
            PayableAmount = payableAmount,
            CurrentAgentProfit = SlotProfit(display.Slot0),
            ChildAgentProfit = SlotProfit(display.Slot1),
            GrandChildAgentProfit = SlotProfit(display.Slot2)
        };
    }

    AgentSettlementRow BuildEmptyMemberRow(DMember member, Dictionary<long, DAgent> agentMap, DateTime monthStart)
    {
        if (!agentMap.TryGetValue(member.DAgentId, out var agent))
            return new AgentSettlementRow();

        var display = GetAgentDisplayInfo(agent, agentMap);
        var chain = BuildChainRootToAgent(agent, agentMap);
        decimal ratioCol = Tier2RebateRate + Tier3RebateRate;
        var rateText = FormatPayableRateText();
        if (chain.Count < 2)
        {
            ratioCol = 0;
            rateText = "—（无二级、三级代理）";
        }

        return new AgentSettlementRow
        {
            AgentId = agent.Id,
            MemberId = member.Id,
            Month = monthStart,
            MonthText = monthStart.ToString("yyyy-MM"),
            CurrentAgentName = display.CurrentAgentName,
            ChildAgentName = display.ChildAgentName,
            GrandChildAgentName = display.GrandChildAgentName,
            MemberName = member.Username,
            TurnoverAmount = 0,
            RechargeAmount = 0,
            Ratio = ratioCol,
            RateText = rateText,
            PayableAmount = 0,
            CurrentAgentProfit = 0,
            ChildAgentProfit = 0,
            GrandChildAgentProfit = 0
        };
    }

    AgentSettlementRow BuildEmptyAgentRow(DAgent agent, Dictionary<long, DAgent> agentMap, DateTime monthStart)
    {
        var display = GetAgentDisplayInfo(agent, agentMap);
        var chain = BuildChainRootToAgent(agent, agentMap);
        decimal ratioCol = Tier2RebateRate + Tier3RebateRate;
        var rateText = FormatPayableRateText();
        if (chain.Count < 2)
        {
            ratioCol = 0;
            rateText = "—（无二级、三级代理）";
        }

        return new AgentSettlementRow
        {
            AgentId = agent.Id,
            Month = monthStart,
            MonthText = monthStart.ToString("yyyy-MM"),
            CurrentAgentName = display.CurrentAgentName,
            ChildAgentName = display.ChildAgentName,
            GrandChildAgentName = display.GrandChildAgentName,
            MemberName = "",
            TurnoverAmount = 0,
            RechargeAmount = 0,
            Ratio = ratioCol,
            RateText = rateText,
            PayableAmount = 0,
            CurrentAgentProfit = 0,
            ChildAgentProfit = 0,
            GrandChildAgentProfit = 0
        };
    }

    // 应付金额对应比例文案：仅二级 + 三级。
    string FormatPayableRateText()
    {
        var payableRate = Tier2RebateRate + Tier3RebateRate;
        return $"{payableRate.ToString("P2", CultureInfo.InvariantCulture)}（{Tier2RebateRate.ToString("P2", CultureInfo.InvariantCulture)}+{Tier3RebateRate.ToString("P2", CultureInfo.InvariantCulture)}）";
    }

    // 非 admin：以登录账号关联代理为锚点，在「根→本条归属代理」链上取从该锚点向下的最多三级（当前代理、一级下级、二级下级）。
    // admin：从组织根向下取三级。
    (DAgent? Slot0, DAgent? Slot1, DAgent? Slot2, string CurrentAgentName, string ChildAgentName, string GrandChildAgentName) GetAgentDisplayInfo(DAgent agent, Dictionary<long, DAgent> agentMap)
    {
        var chain = BuildChainRootToAgent(agent, agentMap);
        if (chain.Count == 0)
            return (null, null, null, "-", "-", "-");

        var isAdmin = string.Equals(AdminContext.User?.Username, "admin", StringComparison.OrdinalIgnoreCase);
        var viewerId = sessionAgent.GetAgentId();

        List<DAgent> slice;
        if (isAdmin)
            slice = chain.Take(3).ToList();
        else if (viewerId <= 0)
            slice = chain.Take(3).ToList();
        else
        {
            var idx = chain.FindIndex(a => a.Id == viewerId);
            slice = idx < 0 ? chain.Take(3).ToList() : chain.Skip(idx).Take(3).ToList();
        }

        var s0 = slice.Count > 0 ? slice[0] : null;
        var s1 = slice.Count > 1 ? slice[1] : null;
        var s2 = slice.Count > 2 ? slice[2] : null;

        static string Cell(DAgent? a) =>
            a == null ? "-" : GetAgentName(a);

        return (s0, s1, s2, Cell(s0), Cell(s1), Cell(s2));
    }

    (string CurrentAgentName, string ChildAgentName, string GrandChildAgentName) GetAgentDisplayNames(DAgent agent, Dictionary<long, DAgent> agentMap)
    {
        var d = GetAgentDisplayInfo(agent, agentMap);
        return (d.CurrentAgentName, d.ChildAgentName, d.GrandChildAgentName);
    }

    // 链末端三级分别对应 Tier1/Tier2/Tier3（链更长时仅末端三级参与分成）。
    static Dictionary<long, decimal> ComputeAgentCommissionShares(List<DAgent> chain, decimal turnover)
    {
        var result = new Dictionary<long, decimal>();
        if (chain.Count == 0 || turnover == 0)
            return result;

        var n = chain.Count;
        if (n == 1)
        {
            result[chain[0].Id] = RoundMoney(turnover * TotalCombinedTierRate);
            return result;
        }

        if (n == 2)
        {
            // 无三级代理：三级份额按一级、二级比例分摊到链上两名代理
            var denom = Tier1RebateRate + Tier2RebateRate;
            var tier3Pool = turnover * Tier3RebateRate;
            decimal extra0 = 0;
            decimal extra1 = 0;
            if (denom > 0)
            {
                extra0 = tier3Pool * (Tier1RebateRate / denom);
                extra1 = tier3Pool * (Tier2RebateRate / denom);
            }

            result[chain[0].Id] = RoundMoney(turnover * Tier1RebateRate + extra0);
            result[chain[1].Id] = RoundMoney(turnover * Tier2RebateRate + extra1);
            return result;
        }

        var i0 = n - 3;
        var i1 = n - 2;
        var i2 = n - 1;
        result[chain[i0].Id] = RoundMoney(turnover * Tier1RebateRate);
        result[chain[i1].Id] = RoundMoney(turnover * Tier2RebateRate);
        result[chain[i2].Id] = RoundMoney(turnover * Tier3RebateRate);
        return result;
    }

    static decimal RoundMoney(decimal v) =>
        Math.Round(v, 2, MidpointRounding.AwayFromZero);

    // 从组织根到指定代理的一条链（根在索引 0，本条在末尾）。
    static List<DAgent> BuildChainRootToAgent(DAgent leaf, Dictionary<long, DAgent> agentMap)
    {
        var up = new List<DAgent>();
        DAgent? cur = leaf;
        var guard = 0;
        while (cur != null && guard++ < 64)
        {
            up.Add(cur);
            if (cur.ParentId <= 0) break;
            if (!agentMap.TryGetValue(cur.ParentId, out cur)) break;
        }

        up.Reverse();
        return up;
    }

    static string GetAgentName(DAgent agent)
    {
        return string.IsNullOrWhiteSpace(agent.AgentName) ? $"ID:{agent.Id}" : agent.AgentName;
    }

    static bool TryParseMonth(string text, out DateTime monthStart, out DateTime nextMonth)
    {
        monthStart = default;
        nextMonth = default;
        if (!DateTime.TryParseExact(text?.Trim(), "yyyy-MM", CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
            return false;

        monthStart = new DateTime(parsed.Year, parsed.Month, 1);
        nextMonth = monthStart.AddMonths(1);
        return true;
    }

