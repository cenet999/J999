@page "/Ddd/DAgentSettlement"
@using System.Globalization
@using J9_Admin.Services
@using J9_Admin.Utils

<PageTitle>代理周结算</PageTitle>

<div class="p-3">
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                <div>
                    <h5 class="mb-1">代理周结算</h5>
                    <div class="text-muted small">按周统计会员投注流水，生成代理、父代理、爷代理三段返利快照。比例：代理 0.8%，父代理 0.5%，爷代理 0.2%；没有父代理或爷代理时，对应金额为 0。</div>
                </div>
                <button type="button" class="btn btn-success" @onclick="GenerateWeekAsync" disabled="@working">
                    @(working ? "处理中..." : "生成 / 重算统计")
                </button>
            </div>

            <div class="row g-2 align-items-end mb-3">
                <div class="col-2">
                    <label class="form-label">周</label>
                    <select class="form-select form-control-sm" value="@queryWeek" @onchange="OnQueryWeekChanged" disabled="@working">
                        @foreach (var option in weekOptions)
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    </select>
                </div>
                <div class="col-2">
                    <label class="form-label">关键词</label>
                    <input @bind="keyword" type="text" class="form-control" placeholder="会员 / 代理" maxlength="50" disabled="@working">
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-primary" @onclick="LoadRowsAsync" disabled="@working">查询</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="ResetFilters" disabled="@working">重置</button>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">流水总计</div>
                        <div class="fs-5 fw-bold">@totalTurnover.ToString("0.##")</div>
                    </div>
                </div>
                <div class="col-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">有效投注</div>
                        <div class="fs-5 fw-bold">@totalValidBet.ToString("0.##")</div>
                    </div>
                </div>
                <div class="col-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">投注笔数</div>
                        <div class="fs-5 fw-bold">@totalBetCount</div>
                    </div>
                </div>
                <div class="col-2">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">返利总计</div>
                        <div class="fs-5 fw-bold text-danger">@totalRebate.ToString("0.##")</div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(loadError))
            {
                <div class="alert alert-warning">@loadError</div>
            }

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">@successMessage</div>
            }

            @if (working)
            {
                <div class="text-muted">数据处理中...</div>
            }
            else if (rows.Count == 0)
            {
                <div class="alert alert-light border">暂无周结算数据，可点击“生成 / 重算本周统计”。</div>
            }
            else
            {
                <div class="mb-4">
                    <div class="fw-semibold mb-2 border-start border-success border-3 ps-2">代理返利汇总</div>
                    @if (agentSummaries.Count == 0)
                    {
                        <div class="text-muted small">暂无</div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var item in agentSummaries)
                            {
                                <div class="col-2">
                                    <div class="card h-100 border-success shadow-sm">
                                        <div class="card-body p-3">
                                            <div class="small text-muted text-truncate" title="@item.Name">@item.Name</div>
                                            <div class="fs-6 fw-bold text-success">@item.Amount.ToString("0.##")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>周</th>
                                <th>会员</th>
                                <th>代理</th>
                                <th>父代理</th>
                                <th>爷代理</th>
                                <th>流水</th>
                                <th>有效投注</th>
                                <th>笔数</th>
                                <th>代理返利</th>
                                <th>父代理返利</th>
                                <th>爷代理返利</th>
                                <th>返利总计</th>
                                <th>状态</th>
                                <th>修改状态</th>
                                <th>确认</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in rows)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.WeekText</td>
                                    <td>@item.MemberName</td>
                                    <td>@item.SourceAgentName</td>
                                    <td>@DisplayName(item.ParentAgentName)</td>
                                    <td>@DisplayName(item.GrandAgentName)</td>
                                    <td>@item.TurnoverAmount.ToString("0.##")</td>
                                    <td>@item.ValidBetAmount.ToString("0.##")</td>
                                    <td>@item.BetTransactionCount</td>
                                    <td><span class="badge bg-success">@item.SourceRebateAmount.ToString("0.##")</span></td>
                                    <td>@item.ParentRebateAmount.ToString("0.##")</td>
                                    <td>@item.GrandRebateAmount.ToString("0.##")</td>
                                    <td class="text-danger fw-bold">@item.TotalRebateAmount.ToString("0.##")</td>
                                    <td>@FormatStatus(item.Status)</td>
                                    <td>
                                        @if (item.Status == AgentSettlementStatus.Paid)
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                        else
                                        {
                                            <select class="form-select form-select-sm" value="@((int)item.SelectedStatus)" @onchange="e => OnRowStatusChanged(item, e)" disabled="@working">
                                                @foreach (var status in statusOptions)
                                                {
                                                    <option value="@((int)status)">@FormatStatus(status)</option>
                                                }
                                            </select>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == AgentSettlementStatus.Paid)
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                        else
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => UpdateRowStatusAsync(item)" disabled="@(working || item.Status == item.SelectedStatus)">
                                                确认
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Inject] IAggregateRootRepository<DAgentWeeklySettlement> repo { get; set; }
    [Inject] AgentWeeklySettlementService settlementService { get; set; }
    [Inject] SessionAgent sessionAgent { get; set; }
    [Inject] AdminContext AdminContext { get; set; }

    List<SettlementViewRow> rows = [];
    List<AgentSummaryItem> agentSummaries = [];
    readonly AgentSettlementStatus[] statusOptions =
    [
        AgentSettlementStatus.Draft,
        AgentSettlementStatus.Confirmed,
        AgentSettlementStatus.Paid,
        AgentSettlementStatus.Voided
    ];
    bool working;
    string loadError = "";
    string successMessage = "";
    const string RecentFourWeeksValue = "__recent_4_weeks__";
    string queryWeek = RecentFourWeeksValue;
    string keyword = "";
    DateTime businessToday = DateTime.Today;
    List<WeekOption> weekOptions = [];
    decimal totalTurnover;
    decimal totalValidBet;
    decimal totalRebate;
    int totalBetCount;

    protected override async Task OnInitializedAsync()
    {
        weekOptions = BuildWeekOptions(businessToday);
        await LoadRowsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var browserTodayText = await JS.InvokeAsync<string>(
            "eval",
            "(() => { const d = new Date(); const m = String(d.getMonth() + 1).padStart(2, '0'); const day = String(d.getDate()).padStart(2, '0'); return d.getFullYear() + '-' + m + '-' + day; })()");

        if (!DateTime.TryParseExact(browserTodayText, "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var browserToday))
            return;

        if (browserToday.Date == businessToday.Date)
            return;

        businessToday = browserToday.Date;
        weekOptions = BuildWeekOptions(businessToday);
        await LoadRowsAsync();
        StateHasChanged();
    }

    async Task OnQueryWeekChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        queryWeek = string.IsNullOrWhiteSpace(value) ? RecentFourWeeksValue : value;

        await LoadRowsAsync();
    }

    async Task GenerateWeekAsync()
    {
        working = true;
        loadError = "";
        successMessage = "";

        try
        {
            var weekStarts = GetSelectedWeekStarts();
            if (weekStarts.Count == 0)
            {
                loadError = "周格式不对，请选择有效周。";
                return;
            }

            var visibleAgentIds = await BuildVisibleAgentIdsAsync();
            if (visibleAgentIds.Count == 0)
            {
                loadError = "当前账号没有可生成的代理数据。";
                return;
            }

            var results = new List<GenerateAgentWeeklySettlementResult>();
            foreach (var weekStart in weekStarts)
                results.Add(await settlementService.GenerateAsync(weekStart, visibleAgentIds));

            successMessage = results.Count == 1
                ? $"已生成 {results[0].WeekKey}：{results[0].RowCount} 条会员统计，投注 {results[0].BetTransactionCount} 笔，流水 {results[0].TurnoverAmount:0.##}，返利 {results[0].TotalRebateAmount:0.##}。"
                : $"已生成最近 {results.Count} 周：{results.Sum(x => x.RowCount)} 条会员统计，投注 {results.Sum(x => x.BetTransactionCount)} 笔，流水 {results.Sum(x => x.TurnoverAmount):0.##}，返利 {results.Sum(x => x.TotalRebateAmount):0.##}。";
            await LoadRowsCoreAsync();
        }
        catch (Exception ex)
        {
            loadError = $"生成失败：{ex.Message}";
        }
        finally
        {
            working = false;
        }
    }

    async Task LoadRowsAsync()
    {
        working = true;
        loadError = "";
        successMessage = "";

        try
        {
            await LoadRowsCoreAsync();
        }
        catch (Exception ex)
        {
            loadError = $"加载失败：{ex.Message}";
        }
        finally
        {
            working = false;
        }
    }

    async Task LoadRowsCoreAsync()
    {
        rows = [];
        agentSummaries = [];
        totalTurnover = 0;
        totalValidBet = 0;
        totalRebate = 0;
        totalBetCount = 0;

        var selectedWeekStarts = GetSelectedWeekStarts();
        if (selectedWeekStarts.Count == 0)
        {
            loadError = "周格式不对，请选择有效周。";
            return;
        }

        var visibleAgentIds = await BuildVisibleAgentIdsAsync();

        if (visibleAgentIds.Count == 0)
        {
            loadError = "当前账号没有可查看的代理数据。";
            return;
        }

        var visibleAgentIdList = visibleAgentIds.ToList();
        var data = await repo.Orm.Select<DAgentWeeklySettlement>()
            .Where(x => selectedWeekStarts.Contains(x.WeekStartDate))
            .Where(x => visibleAgentIdList.Contains(x.SourceAgentId)
                || visibleAgentIdList.Contains(x.ParentAgentId)
                || visibleAgentIdList.Contains(x.GrandAgentId))
            .ToListAsync();

        if (!string.IsNullOrWhiteSpace(keyword))
        {
            var text = keyword.Trim();
            data = data.Where(x =>
                x.MemberName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                x.SourceAgentName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                x.ParentAgentName.Contains(text, StringComparison.OrdinalIgnoreCase) ||
                x.GrandAgentName.Contains(text, StringComparison.OrdinalIgnoreCase)).ToList();
        }

        rows = data
            .OrderByDescending(x => x.WeekStartDate)
            .ThenByDescending(x => x.TotalRebateAmount)
            .ThenBy(x => x.SourceAgentName)
            .ThenBy(x => x.MemberName)
            .Select((x, index) => new SettlementViewRow
            {
                Id = index + 1,
                SettlementId = x.Id,
                WeekText = FormatWeekText(x.WeekKey, x.WeekStartDate, x.WeekEndDate, businessToday),
                MemberName = x.MemberName,
                SourceAgentName = x.SourceAgentName,
                ParentAgentName = x.ParentAgentName,
                GrandAgentName = x.GrandAgentName,
                TurnoverAmount = x.TurnoverAmount,
                ValidBetAmount = x.ValidBetAmount,
                BetTransactionCount = x.BetTransactionCount,
                SourceRebateAmount = x.SourceRebateAmount,
                ParentRebateAmount = x.ParentRebateAmount,
                GrandRebateAmount = x.GrandRebateAmount,
                TotalRebateAmount = x.TotalRebateAmount,
                Status = x.Status,
                SelectedStatus = x.Status
            })
            .ToList();

        totalTurnover = rows.Sum(x => x.TurnoverAmount);
        totalValidBet = rows.Sum(x => x.ValidBetAmount);
        totalBetCount = rows.Sum(x => x.BetTransactionCount);
        totalRebate = rows.Sum(x => x.TotalRebateAmount);
        RebuildAgentSummaries(data);
    }

    async Task<HashSet<long>> BuildVisibleAgentIdsAsync()
    {
        var agents = await repo.Orm.Select<DAgent>().ToListAsync();
        return VisibleAgentIdsHelper.Build(
            agents,
            string.Equals(AdminContext.User?.Username, "admin", StringComparison.OrdinalIgnoreCase),
            sessionAgent.GetAgentId());
    }

    void OnRowStatusChanged(SettlementViewRow item, ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value) && Enum.IsDefined(typeof(AgentSettlementStatus), value))
            item.SelectedStatus = (AgentSettlementStatus)value;
    }

    async Task UpdateRowStatusAsync(SettlementViewRow item)
    {
        working = true;
        loadError = "";
        successMessage = "";

        try
        {
            var currentStatus = await repo.Orm.Select<DAgentWeeklySettlement>()
                .Where(x => x.Id == item.SettlementId)
                .ToOneAsync(x => x.Status);

            if (currentStatus == AgentSettlementStatus.Paid)
            {
                item.Status = AgentSettlementStatus.Paid;
                item.SelectedStatus = AgentSettlementStatus.Paid;
                loadError = "已付款状态不可再修改。";
                return;
            }

            if (item.SelectedStatus == AgentSettlementStatus.Paid)
            {
                var confirmed = await JS.InvokeAsync<bool>(
                    "confirm",
                    $"确认将 {item.MemberName}（{item.WeekText}）标记为已付款吗？已付款后状态不可再修改。");

                if (!confirmed)
                    return;
            }

            var affected = await repo.Orm.Update<DAgentWeeklySettlement>()
                .Set(x => x.Status, item.SelectedStatus)
                .Where(x => x.Id == item.SettlementId)
                .Where(x => x.Status != AgentSettlementStatus.Paid)
                .ExecuteAffrowsAsync();

            if (affected <= 0)
            {
                loadError = "状态更新失败，记录可能已不存在。";
                return;
            }

            item.Status = item.SelectedStatus;
            successMessage = $"已将 {item.MemberName}（{item.WeekText}）状态更新为 {FormatStatus(item.Status)}。";
        }
        catch (Exception ex)
        {
            loadError = $"状态更新失败：{ex.Message}";
        }
        finally
        {
            working = false;
        }
    }

    void ResetFilters()
    {
        queryWeek = RecentFourWeeksValue;
        keyword = "";
        _ = LoadRowsAsync();
    }

    List<DateTime> GetSelectedWeekStarts()
    {
        if (string.IsNullOrWhiteSpace(queryWeek) || queryWeek == RecentFourWeeksValue)
            return GetRecentWeekStarts(4, businessToday);

        return TryParseWeek(queryWeek, out var weekStart)
            ? [weekStart]
            : [];
    }

    static List<DateTime> GetRecentWeekStarts(int count, DateTime today)
    {
        var current = AgentWeeklySettlementService.NormalizeWeekStart(today);
        var list = new List<DateTime>();
        for (var i = 0; i < count; i++)
            list.Add(current.AddDays(-7 * i));

        return list;
    }

    void RebuildAgentSummaries(List<DAgentWeeklySettlement> data)
    {
        var map = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

        foreach (var item in data)
        {
            AddAmount(item.SourceAgentName, item.SourceRebateAmount);
            AddAmount(item.ParentAgentName, item.ParentRebateAmount);
            AddAmount(item.GrandAgentName, item.GrandRebateAmount);
        }

        agentSummaries = map
            .Select(x => new AgentSummaryItem { Name = x.Key, Amount = x.Value })
            .Where(x => x.Amount > 0)
            .OrderByDescending(x => x.Amount)
            .ThenBy(x => x.Name)
            .ToList();

        void AddAmount(string name, decimal amount)
        {
            if (string.IsNullOrWhiteSpace(name) || amount <= 0)
                return;

            map[name] = map.GetValueOrDefault(name) + amount;
        }
    }

    static List<WeekOption> BuildWeekOptions(DateTime today)
    {
        var list = new List<WeekOption>
        {
            new() { Value = RecentFourWeeksValue, Text = "最近 4 周" }
        };
        var current = AgentWeeklySettlementService.NormalizeWeekStart(today);
        for (var i = 0; i < 12; i++)
        {
            var weekStart = current.AddDays(-7 * i);
            var weekEnd = weekStart.AddDays(7);
            var key = AgentWeeklySettlementService.BuildWeekKey(weekStart);
            list.Add(new WeekOption
            {
                Value = key,
                Text = FormatWeekText(key, weekStart, weekEnd, today)
            });
        }

        return list;
    }

    static string FormatWeekText(string weekKey, DateTime weekStart, DateTime weekEnd) =>
        FormatWeekText(weekKey, weekStart, weekEnd, DateTime.Today);

    static string FormatWeekText(string weekKey, DateTime weekStart, DateTime weekEnd, DateTime today)
    {
        var weekLastDay = weekEnd.AddDays(-1);
        var displayEnd = today >= weekStart && today < weekEnd ? today : weekLastDay;
        return $"{weekKey}（{weekStart:yyyy-MM-dd} 至 {displayEnd:yyyy-MM-dd}）";
    }

    static bool TryParseWeek(string text, out DateTime weekStart)
    {
        weekStart = default;
        var parts = text?.Trim().Split("-W", StringSplitOptions.RemoveEmptyEntries);
        if (parts == null || parts.Length != 2)
            return false;

        if (!int.TryParse(parts[0], out var year) || !int.TryParse(parts[1], out var week))
            return false;

        if (week < 1 || week > 53)
            return false;

        try
        {
            weekStart = ISOWeek.ToDateTime(year, week, DayOfWeek.Monday);
            return true;
        }
        catch
        {
            return false;
        }
    }

    static string DisplayName(string name) =>
        string.IsNullOrWhiteSpace(name) ? "-" : name;

    static string FormatStatus(AgentSettlementStatus status) =>
        status switch
        {
            AgentSettlementStatus.Confirmed => "已确认",
            AgentSettlementStatus.Paid => "已付款",
            AgentSettlementStatus.Voided => "已作废",
            _ => "草稿"
        };

    class WeekOption
    {
        public string Value { get; set; } = "";
        public string Text { get; set; } = "";
    }

    class SettlementViewRow
    {
        public int Id { get; set; }
        public long SettlementId { get; set; }
        public string WeekText { get; set; } = "";
        public string MemberName { get; set; } = "";
        public string SourceAgentName { get; set; } = "";
        public string ParentAgentName { get; set; } = "";
        public string GrandAgentName { get; set; } = "";
        public decimal TurnoverAmount { get; set; }
        public decimal ValidBetAmount { get; set; }
        public int BetTransactionCount { get; set; }
        public decimal SourceRebateAmount { get; set; }
        public decimal ParentRebateAmount { get; set; }
        public decimal GrandRebateAmount { get; set; }
        public decimal TotalRebateAmount { get; set; }
        public AgentSettlementStatus Status { get; set; }
        public AgentSettlementStatus SelectedStatus { get; set; }
    }

    class AgentSummaryItem
    {
        public string Name { get; set; } = "";
        public decimal Amount { get; set; }
    }
}
