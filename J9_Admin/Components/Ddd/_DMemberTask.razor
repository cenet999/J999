@page "/Ddd/DMemberTask"
@using J9_Admin.Entities

<AdminTable2 TItem="DMemberTask" Context="item" PageSize="50" Title="会员任务记录" DialogClassName="modal-lg"
    OnQuery="OnQuery" InitQuery="InitQuery" OnEdit="OnEdit">

    <TableHeader>
        <th style="width: 140px;">会员名称</th>
        <th>任务名称</th>
        <th>日期</th>
        <th>当前进度</th>
        <th>状态 (0未完成, 1可领取, 2已领取)</th>
        <th>创建时间</th>
        <th>更新时间</th>
    </TableHeader>
    <TableRow>
        <td style="max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
            title="@GetMemberDisplayName(item.DMember, item.DMemberId)">
            @GetMemberDisplayName(item.DMember, item.DMemberId)
        </td>
        <td>@(item.DTask?.Title ?? "-")</td>
        <td>@item.TaskDate.ToString("yyyy-MM-dd")</td>
        <td>@item.CurrentValue</td>
        <td>
            @switch (item.Status)
            {
                case 0: <span class="badge bg-secondary">未完成</span>; break;
                case 1: <span class="badge bg-warning">可领取</span>; break;
                case 2: <span class="badge bg-success">已领取</span>; break;
                default: @item.Status; break;
            }
        </td>
        <td>@item.CreatedTime?.ToString("yyyy-MM-dd HH:mm:ss")</td>
        <td>@item.ModifiedTime?.ToString("yyyy-MM-dd HH:mm:ss")</td>
    </TableRow>
    <EditTemplate>
        <div class="row">
            <div class="form-group col-6">
                <label class="form-label">会员名称</label>
                <input value="@GetMemberDisplayName(item.DMember, item.DMemberId)" class="form-control" disabled />
            </div>
            <div class="form-group col-6">
                <label class="form-label">任务ID</label>
                <input @bind="item.DTaskId" type="number" class="form-control" />
            </div>
            <div class="form-group col-6">
                <label class="form-label">任务日期</label>
                <input @bind="item.TaskDate" type="date" class="form-control" />
            </div>
            <div class="form-group col-6">
                <label class="form-label">当前进度</label>
                <input @bind="item.CurrentValue" type="number" class="form-control" />
            </div>
            <div class="form-group col-6">
                <label class="form-label">状态(0未完成, 1可领取, 2已领取)</label>
                <input @bind="item.Status" type="number" class="form-control" />
            </div>
        </div>
    </EditTemplate> 
</AdminTable2>

@code {
    [Inject] IAggregateRootRepository<DMemberTask> repo { get; set; }

    async Task InitQuery(AdminQueryInfo e)
    {
        e.Filters = new AdminFilterInfo[]
        {
            
        };
        await Task.Yield();
    }
    void OnQuery(AdminQueryEventArgs<DMemberTask> e)
    {
        e.Select.Include(x => x.DMember).Include(x => x.DTask).OrderByDescending(a => a.Id);
    }

    async Task OnEdit(DMemberTask item)
    {
        await Task.Yield();
    }

    string GetMemberDisplayName(DMember member, long memberId)
    {
        if (!string.IsNullOrWhiteSpace(member?.Username))
            return member.Username;

        return $"会员ID:{memberId}";
    }
}
