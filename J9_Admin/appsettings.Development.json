{
	"Serilog": {
		"MinimumLevel": {
			"Default": "Information",
			"Override": {
				"Microsoft": "Error",
				"System": "Error",
				"J9_Admin": "Debug"
			}
		},
		"WriteTo": [
			{
				"Name": "Console"
			},
			{
				"Name": "File",
				"Args": {
					"path": "Logs/log-.txt",
					"rollingInterval": "Day",
					"outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
				}
			}
		],
		"Enrich": [
			"FromLogContext",
			"WithMachineName",
			"WithThreadId"
		]
	},
	"APIDomain": "http://localhost:5231",
	"Payment": {
		"UsdtAddress": "YOUR_USDT_TRC20_ADDRESS",
		"POPO": {
			"Url": "https://pay.pp.qwgua.com/rest",
			"MchId": "YOUR_POPO_MCH_ID",
			"SecretKey": "YOUR_POPO_SECRET_KEY",
			"Code": "YOUR_POPO_CHANNEL_CODE"
		}
	},
	"TelegramBot": {
		"ApiKey": "YOUR_TELEGRAM_BOT_API_KEY",
		"BotName": "www800800win_test_bot",
		"StartupNotifyChatIds": ""
	},
	"DetailedErrors": true,
	"AllowedOrigins": [
		"https://999137.site",
		"https://*.999137.site",
		"http://localhost:5000",
		"http://localhost:5231",
		"http://localhost:5173",
		"http://localhost:8081",
		"https://app.apifox.com",
		"https://*.apifox.com",
		"https://app.apifox.cn",
		"https://*.apifox.cn"
	],
	"ConnectionStrings": {
		"ActiveProvider": "Sqlite",
		"Sqlite": {
			"DataType": "Sqlite",
			"Default": "Data Source=buyu.db"
		}
	}
}
