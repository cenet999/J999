	},
	"DetailedErrors": true,
	"AllowedOrigins": ["http://localhost:5000", "http://localhost:5231", "http://localhost:5173"],

	"ConnectionStrings": {
		"ActiveProvider": "Sqlite",
		"Sqlite": {
