		<PackageReference Include="AdminBlazor" Version="2.5.4" />

		<PackageReference Include="BootstrapBlazor.CherryMarkdown" Version="9.0.0" />
		<PackageReference Include="Rougamo.Fody" Version="5.0.2" />
