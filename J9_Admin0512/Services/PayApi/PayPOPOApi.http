### 支付下单
### sign source:
### amount=100.00&body=J9 test recharge&code=0000&device=app&ip=43.106.135.22&mchId=287&mchOrderNo=J9TEST20260505120000&notifyUrl=http://43.106.135.22/api/trans/@PayPOPOCallback&requestTime=20260505120000&returnUrl=https://example.com/pay/success&title=J9 Recharge Test&version=1.0 + 商户密钥
# @name createPayPOPOOrder
POST {{gateway}}/pay/create
Content-Type: application/json

{
  "mchId": {{mchId}},
  "version": "{{version}}",
  "requestTime": "20260505120000",
  "code": "{{payCode}}",
  "amount": "{{amount}}",
  "mchOrderNo": "{{mchOrderNo}}",
  "notifyUrl": "{{notifyHost}}/api/trans/@PayPOPOCallback",
  "title": "J9 Recharge Test",
  "ip": "43.106.135.22",
  "body": "J9 test recharge",
  "device": "app",
  "returnUrl": "https://example.com/pay/success",
  "sign": "560ac9f3f6c29f0b7a89e70322cf9a8a"
}

